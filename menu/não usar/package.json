{
  "name": "tawros-api",
  "version": "1.0.0",
  "description": "API REST Fastify + TypeScript para integra��o do sistema TAWROS",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "vitest run src/tests/e2e",
    "test:integracao": "powershell -ExecutionPolicy Bypass -File scripts/test-integracao-completa.ps1",
    "test:integracao:com-unit": "powershell -ExecutionPolicy Bypass -File scripts/test-integracao-completa.ps1 -RunUnitTests",
    "smoke": "node scripts/smoke.mjs",
    "db:audit": "tsx scripts/db-audit.ts",
    "perf:autocannon": "autocannon -c 100 -d 20 https://api.sistema.tawros.com.br/api/v1/health"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "kysely": "^0.28.12",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "autocannon": "^8.0.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "light-my-request": "^6.6.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}