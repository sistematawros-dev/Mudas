--- /dev/null
+++ sql/migrations/20260413_002_patio_fluxo_operacional.sql
@@ -0,0 +1,66 @@
+BEGIN;
+
+ALTER TABLE app.instrucoes
+  ADD COLUMN IF NOT EXISTS patio_fase VARCHAR(30) NOT NULL DEFAULT 'aguardando_chegada',
+  ADD COLUMN IF NOT EXISTS chegada_em TIMESTAMPTZ NULL,
+  ADD COLUMN IF NOT EXISTS chamado_em TIMESTAMPTZ NULL,
+  ADD COLUMN IF NOT EXISTS entrada_em TIMESTAMPTZ NULL,
+  ADD COLUMN IF NOT EXISTS finalizado_em TIMESTAMPTZ NULL,
+  ADD COLUMN IF NOT EXISTS ordem_fila INTEGER NULL,
+  ADD COLUMN IF NOT EXISTS quantidade_real NUMERIC(14,3) NULL;
+
+ALTER TABLE app.instrucoes
+  DROP CONSTRAINT IF EXISTS ck_instrucoes_patio_fase;
+
+ALTER TABLE app.instrucoes
+  ADD CONSTRAINT ck_instrucoes_patio_fase
+  CHECK (patio_fase IN ('aguardando_chegada', 'fila_patio', 'chamado', 'carregando', 'finalizado'));
+
+ALTER TABLE app.instrucoes
+  DROP CONSTRAINT IF EXISTS ck_instrucoes_ordem_fila;
+
+ALTER TABLE app.instrucoes
+  ADD CONSTRAINT ck_instrucoes_ordem_fila
+  CHECK (ordem_fila IS NULL OR ordem_fila >= 1);
+
+ALTER TABLE app.instrucoes
+  DROP CONSTRAINT IF EXISTS ck_instrucoes_quantidade_real;
+
+ALTER TABLE app.instrucoes
+  ADD CONSTRAINT ck_instrucoes_quantidade_real
+  CHECK (quantidade_real IS NULL OR quantidade_real >= 0);
+
+UPDATE app.instrucoes
+SET patio_fase = CASE
+  WHEN status = 'finalizado' THEN 'finalizado'
+  WHEN status = 'recusado' THEN 'aguardando_chegada'
+  WHEN status = 'aprovado' THEN 'aguardando_chegada'
+  ELSE 'aguardando_chegada'
+END
+WHERE patio_fase IS NULL OR patio_fase = '';
+
+UPDATE app.instrucoes
+SET finalizado_em = COALESCE(finalizado_em, updated_at)
+WHERE status = 'finalizado' AND finalizado_em IS NULL;
+
+CREATE INDEX IF NOT EXISTS idx_instrucoes_patio_fase
+  ON app.instrucoes (patio_fase)
+  WHERE deleted_at IS NULL;
+
+CREATE INDEX IF NOT EXISTS idx_instrucoes_chegada_em
+  ON app.instrucoes (chegada_em)
+  WHERE deleted_at IS NULL AND chegada_em IS NOT NULL;
+
+CREATE INDEX IF NOT EXISTS idx_instrucoes_ordem_fila
+  ON app.instrucoes (ordem_fila)
+  WHERE deleted_at IS NULL AND ordem_fila IS NOT NULL;
+
+COMMIT;
